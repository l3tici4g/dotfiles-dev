#: SHELL
shell /usr/bin/zsh
shell_integration no-cursor

#: KEYBOARD SHORTCUTS
kitty_mod ctrl+shift
map ctrl+shift+f11 toggle_fullscreen

#: WINDOW
window_padding_width 10
window_margin_width 5
window_border_width 1.5pt
# active_border_color #f6c177
# inactive_border_color #393552
#: Alternaativa para a opção 'fullscreen':
hide_window_decorations yes

##: LAYOUTS
enabled_layouts tall

##: BACKGROUND
background_opacity 0.87
#: default background_opacity 1
#: Somente suportada no macOS e no KDE:
# background_blur 50

##: TAB
tab_bar_style powerline
tab_powerline_style angled
tab_activity_symbol *

#: CURSOR
# cursor #f8f8f8
# cursor_text_color #110f18
cursor_shape block
cursor_blink_interval 1

##: SCROLLING / SCROLLBACK
scrollback_lines 10000
scrollback_pager_history_size 10000
wheel_scroll_multiplier 3.0

#: FONTS
font_family      Fira Code Nerd Font Mono
bold_font        Fira Code Nerd Font Mono Bold
italic_font      JetBrains Mono Italic
bold_italic_font JetBrains Mono Bold Italic
font_size 15.0

#: TERMINAL THEME
# BEGIN_KITTY_THEME
# Rosé Pine
include current-theme.conf
# END_KITTY_THEME
