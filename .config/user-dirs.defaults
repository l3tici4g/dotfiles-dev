# Default settings for user directories
#
# The values are relative pathnames from the home directory and
# will be translated on a per-path-element basis into the users locale
DESKTOP=Desktop
DOWNLOAD=/home/$USER/downloads
TEMPLATES=/home/$USER/models
PUBLICSHARE=/home/$USER/public
DOCUMENTS=/home/$USER/media/documents
MUSIC=/home/$USER/media/music
PICTURES=/home/$USER/media/images
VIDEOS=/home/$USER/media/videos

