// #: Waybar Config
// -*- mode: jsonc -*-
[
  {
    "name": "mainBar",

    // #: Layout
    "layer": "top",
    "position": "top",
    "height": 16,
    "spacing": 1,

    // #: Modules position
    "modules-left": ["group/session", "custom/launcher", "clock"],
    "modules-center": ["sway/workspaces"],
    "modules-right": [
      "tray",
      // "bluetooth",
      "network",
      "pulseaudio",
      "backlight",
      // "custom/gamma",
      // "custom/keyboard-layout",
      // "memory",
      // "cpu",
      // "custom/cpu",
      "temperature",
      "battery",
      "power-profiles-daemon",
    ],

    // #: Import Modules Settings
    "include": "./modules.jsonc",

    // #: Reloading the CSS Style if a modification is detected
    "reload_style_on_change": true,
  },
]

